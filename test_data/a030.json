r blocking","warning":"After sensor blocking"},"radar":{"engagement":"Partial blockage after sensor blocking","warning":"After sensor blocking"}}}},"unresponsiveDriverIntervention":{"score":20,"maxScore":25,"verdict":"GREEN"},"collisionAvoidance":{"score":44.9,"maxScore":50,"verdict":"GREEN","scenarios":{"approachingStationaryTarget":{"car":"GREEN","motorcycle":"YELLOW"},"approachingSlowerMovingTarget":{"car":"GREEN","motorcycle":"GREEN"},"approachingBrakingTarget":{"car":"GREEN","motorcycle":"GREEN"},"targetCuttingInFront":{"car":"GREEN","motorcycle":"GREEN"},"carCuttingOutInFrontToExposeTarget":{"car":"GREEN","motorcycle":"ORANGE"},"approachingTargetAlongRoadside":{"vulnerableRoadUser":"GREEN"}}}}}}}},"carSafety":null,"carAssistedDriving":{"assistedDrivingGrading":{"code":"VERY_GOOD","name":"Very good"},"assistedDrivingPackName":"TOYOTA SAFETY SENSE","safetyAssessmentId":"1163","assessmentReviews":[]},"truckSafety":null,"vanSafety":null,"model":{"id":"a8311cf7-3e33-4420-9327-67e82371dc2a","createdAt":"2026-01-21T19:17:41.168548+00:00","updatedAt":"2026-01-21T19:17:41.168548+00:00","code":"TOYOTA_BZ4X","name":"bZ4X","class":{"code":"SMALL_SUV","name":"Small SUV"},"vehicleType":{"code":"CAR","name":"Car"}},"make":{"id":"0a4a0784-1fb3-47d6-8e5e-836296b7f0b4","createdAt":"2026-01-21T19:13:59.283549+00:00","updatedAt":"2026-03-19T12:56:09.497816+00:00","code":"TOY","name":"Toyota","logoPath":"https://data-cdn.euroncap.com/media/make-logo/TOY_logo__850be12d200e6228_original.svg","negLogoPath":"https://data-cdn.euroncap.com/media/make-logo/TOY_negLogo__9d6d7ab115be4ba9_original.svg","logo":{"url":"https://data-cdn.euroncap.com/media/make-logo/TOY_logo__850be12d200e6228_original.svg","width":null,"height":null,"formats":null},"negativeLogo":{"url":"https://data-cdn.euroncap.com/media/make-logo/TOY_negLogo__9d6d7ab115be4ba9_original.svg","width":null,"height":null,"formats":null}},"assessmentMedia":[{"id":"7fffaeb4-6804-4058-800b-16fc484cf513","createdAt":"2026-03-24T10:40