fter sensor blocking"}},"sensorBlockedVehicleMovingSystemActive":{"camera":{"engagement":"Full blockage within 2 minutes after blocking","warning":"After sensor blocking"},"radar":{"engagement":"Partial blockage after sensor blocking","warning":"After sensor blocking"}}}},"unresponsiveDriverIntervention":{"score":0,"maxScore":25,"verdict":"RED"},"collisionAvoidance":{"score":29.2,"maxScore":50,"verdict":"YELLOW","scenarios":{"approachingStationaryTarget":{"car":"ORANGE","motorcycle":"BROWN"},"approachingSlowerMovingTarget":{"car":"GREEN","motorcycle":"YELLOW"},"approachingBrakingTarget":{"car":"GREEN","motorcycle":"YELLOW"},"targetCuttingInFront":{"car":"GREEN","motorcycle":"YELLOW"},"carCuttingOutInFrontToExposeTarget":{"car":"YELLOW","motorcycle":"RED"},"approachingTargetAlongRoadside":{"vulnerableRoadUser":"YELLOW"}}}}}}}},"carSafety":null,"carAssistedDriving":{"assistedDrivingGrading":{"code":"NOT_RECOMMENDED","name":"Not recommended"},"assistedDrivingPackName":"Adaptive Cruise Control","safetyAssessmentId":"0992","assessmentReviews":[]},"truckSafety":null,"vanSafety":null,"model":{"id":"240274d9-2df0-40f3-916a-a5e5642c3ecb","createdAt":"2026-01-21T19:16:09.862278+00:00","updatedAt":"2026-01-21T19:16:09.862278+00:00","code":"BYD_ATTO_3","name":"ATTO 3","class":{"code":"SMALL_SUV","name":"Small SUV"},"vehicleType":{"code":"CAR","name":"Car"}},"make":{"id":"95c4e599-8f10-44c5-be3f-daf671e0ccc0","createdAt":"2026-01-21T19:13:43.83494+00:00","updatedAt":"2026-03-19T12:55:51.067923+00:00","code":"BYD","name":"BYD","logoPath":"https://data-cdn.euroncap.com/media/make-logo/BYD_pos__779a9bdbaa212b79_original.svg","negLogoPath":"https://data-cdn.euroncap.com/media/make-logo/BYD_neg__d2bd336ef68127f8_original.svg","logo":{"url":"https://data-cdn.euroncap.com/media/make-logo/BYD_pos__779a9bdbaa212b79_original.svg","width":547,"height":108,"formats":{"large":{"url":"https://data-cdn.euroncap.com/media/make-logo/BYD_pos__2893405104266de2_lg.webp","width":547,"height":108},"s